    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "mammoth": "^1.9.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.3",
    "node-cron": "^3.0.3",
    "pdf-parse": "^1.1.1",
    "playwright": "^1.52.0",
    "resend": "^4.5.1",
    "stripe": "^17.7.0",
    "zod": "^3.25.22"
